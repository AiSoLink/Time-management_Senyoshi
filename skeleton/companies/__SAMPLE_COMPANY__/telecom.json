{
  "meta": {
    "device_type": "telecom",
    "version": "1.0"
  },
  "header_extract": {
    "report_id_regex": "(ID-\\d+)",
    "run_date_regex": "(運行日付|運行日)\\s*[:：]?\\s*(\\d{4}/\\d{1,2}/\\d{1,2})",
    "driver_regex": "乗務員名\\s*[:：]\\s*(.+?)\\s*\\((\\d+)\\)",
    "vehicle_regex": "車両名称\\s*[:：]\\s*(.+?)\\s*\\((\\d+)\\)",
    "office_regex": "所\\s*属\\s*[:：]\\s*(.+?)\\s*\\((\\d+)\\)",
    "meter_out_regex": "出庫時刻\\s*[:：]\\s*\\d{4}/\\d{1,2}/\\d{1,2}\\s*\\d{2}:\\d{2}\\s*([0-9]+(?:\\.[0-9]+)?)\\s*km",
    "meter_in_regex": "帰庫時刻\\s*[:：]\\s*\\d{4}/\\d{1,2}/\\d{1,2}\\s*\\d{2}:\\d{2}\\s*([0-9]+(?:\\.[0-9]+)?)\\s*km",
    "header_out_dt_regex": "出庫時刻\\s*[:：]\\s*(\\d{4}/\\d{1,2}/\\d{1,2}\\s*\\d{2}:\\d{2})",
    "header_in_dt_regex": "帰庫時刻\\s*[:：]\\s*(\\d{4}/\\d{1,2}/\\d{1,2}\\s*\\d{2}:\\d{2})",
    "score_safe_regex": "安全運転\\s*([0-9]+)\\s*点"
  }
}